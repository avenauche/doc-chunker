{
  "name": "doc-chunker",
  "version": "1.0.0",
  "type": "module",
  "description": "Document chunking service powered by LangChain.js",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "install:deps": "npm install --legacy-peer-deps",
    "docker:build": "docker build -t doc-chunker .",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f"
  },
  "dependencies": {
    "@llamaindex/liteparse": "^1.3.1",
    "@xenova/transformers": "^2.17.2",
    "cors": "^2.8.6",
    "express": "^4.18.2",
    "express-handlebars": "^7.1.2",
    "multer": "^1.4.5-lts.1",
    "semantic-chunking": "^2.4.4",
    "voy-search": "^0.6.3"
  },
  "devDependencies": {
    "nodemon": "^3.0.0"
  }
}
